rules_version = '2';

// All reads/writes go through the Cloud Run backend which uses Firebase Admin SDK
// (admin SDK bypasses these rules). These rules are a defense-in-depth lockout
// for anyone who tries to hit Firestore directly with a client SDK.
//
// To allow a specific client-side read pattern, add a targeted allow rule here.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
