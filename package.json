{
  "name": "eshipperplus-crm",
  "version": "0.1.0",
  "description": "eShipper Plus CRM — MVP Phase 1 (sales pipeline, onboarding, partner intake)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "seed": "node dev_setup.js",
    "test": "jest --forceExit",
    "test:watch": "jest --watch --forceExit",
    "test:coverage": "jest --coverage --forceExit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "firebase-admin": "^12.0.0",
    "googleapis": "^144.0.0",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=20"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
